{
  "name": "@storacha/clawracha",
  "version": "0.1.2",
  "description": "OpenClaw plugin for Storacha workspace sync via UCN Pail",
  "type": "module",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/plugin.js",
  "types": "dist/plugin.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/plugin.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "keywords": [
    "openclaw",
    "storacha",
    "sync",
    "ucn",
    "pail"
  ],
  "author": "Storacha",
  "license": "Apache-2.0 OR MIT",
  "packageManager": "pnpm@10.29.3",
  "dependencies": {
    "@ipld/car": "^5.2.0",
    "@ipld/dag-cbor": "^9.2.5",
    "@storacha/client": "^2.0.4",
    "@storacha/md-merge": "0.6.0",
    "@storacha/ucn": "1.1.1-rc.3",
    "@storacha/upload-client": "^1.3.9",
    "@ucanto/interface": "^11.0.1",
    "@web3-storage/pail": "0.6.3-rc.3",
    "carstream": "^2.3.0",
    "chokidar": "^3.6.0",
    "glob": "^13.0.5",
    "multiformats": "^13.0.0"
  },
  "devDependencies": {
    "@ipld/unixfs": "^3.0.0",
    "@types/node": "^20.0.0",
    "@ucanto/client": "^9.0.2",
    "@ucanto/principal": "^9.0.3",
    "@ucanto/transport": "^9.2.1",
    "openclaw": ">=2026.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.1.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.0.0"
  }
}
